            ],
            [
              "y",
              2
            ]
          ]
        }
      }
    ],
    "ops": [
      {
        "op": 5,
        "path": [
          {
            "field": 1
          }
        ],
        "keyType": "string",
        "key": "x",
        "valueType": 1,
        "value": 99
      }
    ],
    "expected_chain_bytes_hex": "0101050001030001780163",
    "expected_final": [
      {
        "num": 1,
        "map": {
          "keyType": "string",
          "valueType": 1,
          "entries": [
            [
              "x",
