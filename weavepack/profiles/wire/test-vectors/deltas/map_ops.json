[
  {
    "name": "map_set creates entry",
    "description": "set a map entry in a map that doesn't exist yet",
    "initial": [],
    "ops": [
      {
        "op": 5,
        "path": [
          {
            "field": 1
          }
        ],
        "keyType": "string",
        "key": "x",
        "valueType": 1,
        "value": 42
      }
    ],
    "expected_chain_bytes_hex": "010105000103000178012a",
    "expected_final": [
      {
        "num": 1,
        "map": {
          "keyType": "string",
          "valueType": 1,
          "entries": [
            [
              "x",
              42
            ]
          ]
        }
      }
    ]
  },
  {
