      {
        "num": 1,
        "map": {
          "keyType": "string",
          "valueType": 9,
          "entries": [
            [
              "a",
              "alpha"
            ],
            [
              "b",
              "beta"
            ]
          ]
        }
      }
    ],
    "ops": [
      {
        "op": 6,
        "path": [
          {
            "field": 1
          }
        ],
        "keyType": "string",
        "key": "a"
      }
    ],
    "expected_chain_bytes_hex": "010106000103000161",
    "expected_final": [
      {
        "num": 1,
        "map": {
          "keyType": "string",
          "valueType": 9,
          "entries": [
