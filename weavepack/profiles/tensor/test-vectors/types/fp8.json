[
  {
    "name": "fp8e4m3 unit values",
    "description": "fp8e4m3 round-trip: 0, 1, -1, 0.5 as Float32 input",
    "input": {
      "tensors": {
        "t": {
          "dtype": 11,
          "shape": [4],
          "data": [0, 1, -1, 0.5]
        }
      }
    },
    "expected_bytes_hex": "0045d162080071706000",
    "expected_bits": [0, 56, 184, 48]
  },
  {
    "name": "fp8e4m3 max-finite",
    "description": "448 is the largest finite fp8e4m3 value (exp=15, mant=6; S.1111.110)",
    "input": {
      "tensors": {
        "t": {
          "dtype": 11,
          "shape": [1],
          "data": [448]
        }
      }
    },
    "expected_bytes_hex": "0045d16202fc00",
    "expected_bits": [126]
  },
  {
    "name": "fp8e4m3 smallest subnormal",
    "description": "2^-9 ≈ 0.001953 is the smallest non-zero fp8e4m3 value (exp=0, mant=1)",
    "input": {
      "tensors": {
        "t": {
          "dtype": 11,
          "shape": [1],
          "data": [0.001953125]
        }
      }
    },
    "expected_bytes_hex": "0045d162020200",
    "expected_bits": [1]
  },
  {
    "name": "fp8e4m3 saturation",
    "description": "Overflow (1e38 >> 448) saturates to max-finite; fp8e4m3 has no Infinity",
    "input": {
      "tensors": {
        "t": {
          "dtype": 11,
          "shape": [1],
          "data": [1e38]
        }
      }
    },
    "expected_bytes_hex": "0045d16202fc00",
    "expected_bits": [126]
  },
  {
    "name": "fp8e4m3 NaN",
    "description": "Canonical NaN in fp8e4m3 is 0x7F (S.1111.111); only two NaN bit patterns exist",
    "input": {
      "tensors": {
        "t": {
          "dtype": 11,
          "shape": [1],
          "data_raw_bits": [127]
        }
      }
    },
    "expected_bytes_hex": "0045d16202fe00",
    "expected_bits": [127]
  },
  {
    "name": "fp8e4m3 2D matrix",
    "description": "2×2 matrix of powers of 2: encodes as consecutive fp8e4m3 bytes",
    "input": {
      "tensors": {
        "t": {
          "dtype": 11,
          "shape": [2, 2],
          "data": [1, 2, 4, 8]
        }
      }
    },
    "expected_bytes_hex": "0045d1640404708090a000",
    "expected_bits": [56, 64, 72, 80]
  },
  {
    "name": "fp8e5m2 unit values",
    "description": "fp8e5m2 round-trip: 0, 1, -1, 0.5 as Float32 input",
    "input": {
      "tensors": {
        "t": {
          "dtype": 12,
          "shape": [4],
          "data": [0, 1, -1, 0.5]
        }
      }
    },
    "expected_bytes_hex": "0045d182080079787000",
    "expected_bits": [0, 60, 188, 56]
  },
  {
    "name": "fp8e5m2 max-finite",
    "description": "57344 = (1+3/4)×2^15 is the largest finite fp8e5m2 value (exp=30, mant=3)",
    "input": {
      "tensors": {
        "t": {
          "dtype": 12,
          "shape": [1],
          "data": [57344]
        }
      }
    },
    "expected_bytes_hex": "0045d18202f600",
    "expected_bits": [123]
  },
  {
    "name": "fp8e5m2 smallest subnormal",
    "description": "2^-16 ≈ 1.526e-5 is the smallest non-zero fp8e5m2 value (exp=0, mant=1)",
    "input": {
      "tensors": {
        "t": {
          "dtype": 12,
          "shape": [1],
          "data": [0.0000152587890625]
        }
      }
    },
    "expected_bytes_hex": "0045d182020200",
    "expected_bits": [1]
  },
  {
    "name": "fp8e5m2 +Infinity",
    "description": "+Infinity in fp8e5m2 is 0x7C (S.11111.00)",
    "input": {
      "tensors": {
        "t": {
          "dtype": 12,
          "shape": [1],
          "data_raw_bits": [124]
        }
      }
    },
    "expected_bytes_hex": "0045d18202f800",
    "expected_bits": [124]
  },
  {
    "name": "fp8e5m2 -Infinity",
    "description": "-Infinity in fp8e5m2 is 0xFC (S.11111.00 with sign=1)",
    "input": {
      "tensors": {
        "t": {
          "dtype": 12,
          "shape": [1],
          "data_raw_bits": [252]
        }
      }
    },
    "expected_bytes_hex": "0045d18203f800",
    "expected_bits": [252]
  },
  {
    "name": "fp8e5m2 NaN",
    "description": "Canonical qNaN in fp8e5m2 is 0x7F (S.11111.11)",
    "input": {
      "tensors": {
        "t": {
          "dtype": 12,
          "shape": [1],
          "data_raw_bits": [127]
        }
      }
    },
    "expected_bytes_hex": "0045d18202fe00",
    "expected_bits": [127]
  }
]
