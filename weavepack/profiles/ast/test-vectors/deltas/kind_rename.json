        { "nid": "3", "kind": "Id", "parentNid": "1", "childIndex": 1, "props": [ { "colId": 4, "ctype": 11, "value": "b" } ] },
        { "nid": "4", "kind": "Id", "parentNid": "1", "childIndex": 2, "props": [ { "colId": 4, "ctype": 11, "value": "c" } ] }
      ]
    }
  },
  {
